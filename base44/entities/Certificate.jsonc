      "type": "string"
    },
    "course_id": {
      "type": "string"
    },
    "course_title": {
      "type": "string"
    },
    "score": {
      "type": "number"
    },
    "certificate_id": {
      "type": "string"
    },
    "issue_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
